# ================================
# GAMING CONTENT BOT - Configuración
# ================================
# Copiar a .env y llenar con tus keys

# ============ GROQ API ============
# Obtener en: console.groq.com
# Generación de guiones (fallback: Ollama local)
GROQ_API_KEY=your_groq_api_key_here

# ============ REDDIT ============
# Obtener en: reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=gaming-content-bot/1.0

# ============ STEAM API ============
# Obtener en: steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# ============ YOUTUBE ============
# Obtener client_secrets.json en: console.cloud.google.com
# Descargarlo y ponerlo en la raíz del proyecto
# NO usar token aquí — usa OAuth
# (El primer run abre browser para autorizar)

# ============ TIKTOK ============
# Obtener en: developers.tiktok.com
# Content Posting API requiere aprobación (1-3 días)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# ============ INSTAGRAM ============
# Obtener en: developers.facebook.com
# Necesita Business o Creator account (no personal)
INSTAGRAM_ACCESS_TOKEN=your_instagram_long_lived_token
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id

# ============ YOUTUBE API KEY ============
# Para recolectar métricas (Analytics)
# Obtener en: console.cloud.google.com
YOUTUBE_API_KEY=your_youtube_api_key_here

# ============ OLLAMA ============
# URL del servidor Ollama local (fallback para guiones)
# Dejar vacío si usas Groq
OLLAMA_BASE_URL=http://localhost:11434

# ============ DEBUG ============
DEBUG=false
LOG_LEVEL=INFO
